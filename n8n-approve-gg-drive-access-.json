    {
      "parameters": {
        "jsCode": "const data = $input.all().map(x => x.json);\nif (!data.length) {\n  return {\n    lastApproved: new Date('2025-12-01')\n  }\n}\nconst latestItem = data.reduce((latest, current) => {\n    return new Date(current.ApprovedAt) > new Date(latest.ApprovedAt) ? current : latest;\n});\n\n\nreturn {\n  lastApproved: latestItem.ApprovedAt\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        0
      ],
      "id": "6f327c6b-64c2-4ad1-b786-d0aff52afa8d",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst data = []\nfor (const item of $input.all()) {\n  const subject = item.json.Subject || '';\n  const isRequestAccess = /(share\\s+request\\s+for|request(ing|ed)?\\s+access|yêu\\s+cầu\\s+(quyền\\s+)?truy\\s+cập|muốn\\s+truy\\s+cập)/i\n.test(subject);\n  if (isRequestAccess) {\n    const emailRegex = /[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}/gi;\n    const matches = item.json.snippet.match(emailRegex);\n    if (matches && matches.length) {\n      const date =  new Date(Number(item.json.internalDate) + 10000)\n      data.push({\n        email: matches[0],\n        date: date.toISOString(),\n      })\n    }\n  }\n}\n\nreturn data;"
      },
