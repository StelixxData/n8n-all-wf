    {
      "parameters": {
        "jsCode": "const input = $('Gmail Trigger').all();\nconst data = []\nfor (const item of input) {\n  const subject = item.json.Subject || '';\n  const isRequestAccess = /(share\\s+request\\s+for|request(ing|ed)?\\s+access|yêu\\s+cầu\\s+(quyền\\s+)?truy\\s+cập|muốn\\s+truy\\s+cập)/i\n.test(subject);\n  if (isRequestAccess) {\n    const emailRegex = /[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}/gi;\n    const matches = item.json.snippet.match(emailRegex);\n    const folderName = subject.replace(/.*\"([^\"]+)\".*/, '$1');\n    if (matches && matches.length && folderName) {\n      const date =  new Date(Number(item.json.internalDate) + 10000)\n      const from = item.json.From || '';\n      const fromName = from.replace(/.*\"([^\"]+)\".*/, '$1').replace(\"(via Google Drive)\", \"\").trim();\n      data.push({\n        mailId: item.json.id,\n        email: matches[0],\n        approvedAt: date.toISOString(),\n        folderName: folderName,\n        fromName: fromName\n      })\n    }\n  }\n}\n\nreturn data;"
      },
