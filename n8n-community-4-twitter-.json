    {
      "parameters": {
        "jsCode": "var distributionTarget  = $node[\"env\"].json[\"DistributionTarget\"];\n\nvar query = \n`\nSELECT t.Id, t.[Type], t.Text, t.MediaLink\nFROM XinhTelegramMedia t\nINNER JOIN (\n    SELECT TOP 1 m.MessageGroupedId\n    FROM XinhTelegramMedia m\n    LEFT JOIN XinhDistributionLog d ON m.Id = d.SourceId AND d.DistributionTarget <> '${ distributionTarget[\"Username\"] }'\n    WHERE d.SourceId IS NULL\n    ORDER BY NEWID()\n) AS sub ON t.MessageGroupedId = sub.MessageGroupedId;\n`\n\nreturn {\n  query: query\n}\n"
      },
