        "jsCode": "const application = {\n  \"fields\": {\n    \"Source\": $(\"Get Email Data\").item.json[\"source\"],\n    \"LinkCV\": {\n      \"text\": $(\"Upload CV\").item.json[\"name\"],\n      \"link\": $(\"Upload CV\").item.json[\"webViewLink\"]\n    },\n    \"Applied Date\": $(\"Get Email Data\").item.json[\"appliedDate\"],\n    \"Candidate\": [$(\"Create Candidate\").item.json[\"data\"][\"record\"][\"record_id\"]],\n    \"Job\": [$(\"Get Job\").item.json[\"data\"][\"items\"][\"0\"][\"record_id\"]],\n    \"Parsed Json\": $(\"AI Resume Parser\").item.json[\"error\"] ? null : JSON.stringify($(\"AI Resume Parser\").item.json)\n  }\n};\n\nreturn application;\n\n"
