    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const title = $(\"Email Trigger (IMAP)\").item.json[\"subject\"];\nconst fileName = $(\"Email Trigger (IMAP)\").item.binary?.attachment_0.fileName;\nconst emailContent = $(\"Email Trigger (IMAP)\").item.json[\"html\"];\n\n// const fullNameMatch = fileName.match(/_(.*?)\\.pdf/);\n// let candidateName = \"\";\n// if (fullNameMatch && fullNameMatch.length > 1) {\n//     candidateName = fullNameMatch[1];\n// } else {\n//   console.log(\"File name not match the pattern: \", fileName);\n// }\n\ncandidateName = title.split(\"applies for\")[0].replace(\"[TopDev] \", \"\").trim();\n\nlet email = \"\";\nconst emailMatch = emailContent.match(/([a-zA-Z0-9._-]+@[a-zA-Z0-9._-]+\\.[a-zA-Z0-9_-]+)/);\nif (emailMatch && emailMatch.length > 1) {\n  email = emailMatch[1];\n} else {\n  console.error(\"Email not found in the email content\");\n}\n\njobTitle = title.split(\"applies for\")[1].split(\" at \")[0].replace(\"[TopDev] \", \"\").trim();\n\n// // ChatGPT\n// // Sử dụng biểu thức chính quy để tìm kiếm email\n// const emailRegex = /mailto:([a-zA-Z0-9._-]+@[a-zA-Z0-9._-]+\\.[a-zA-Z0-9._-]+)/gi;\n// const emailMatches = emailRegex.exec(emailContent);\n// const emailAI = emailMatches ? emailMatches[1] : 'Không tìm thấy email';\n\n// Sử dụng biểu thức chính quy để tìm kiếm số điện thoại\n// Giả sử số điện thoại ở Việt Nam và không chứa ký tự đặc biệt\nconst phoneRegex = /(\\d{10,11})/g;\nconst phoneMatches = phoneRegex.exec(emailContent);\nconst phoneNumber = phoneMatches ? phoneMatches[0] : '';\n\nif(phoneNumber == null || phoneNumber == '')\n{\n  phoneNumber = \n    $('AI Resume Parser').item.json.error || !$('AI Resume Parser').item.json.output[\"Phone\"] \n      ? null \n      : $('AI Resume Parser').item.json.output[\"Phone\"][\"0\"].replace(/\\D/g, '')\n}\n\nreturn {\n  \"subject\": title,\n  \"candidateName\": candidateName,\n  \"candidateEmail\": email,\n  \"jobTitle\": jobTitle,\n  \"phoneNumber\": phoneNumber,\n  \"source\": \"TopDev\",\n  \"appliedDate\": Date.parse($node[\"Email Trigger (IMAP)\"].json[\"date\"]), // Format: Seconds\n};"
      },
