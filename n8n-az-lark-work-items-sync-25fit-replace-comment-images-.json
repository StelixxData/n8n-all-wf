      "parameters": {
        "jsCode": "var doneBranchUrlMapping = $input.all();\ndoneBranchUrlMapping = doneBranchUrlMapping.map((item) => item.json);\n\nfunction groupBy(arr, prop) {\n    const map = new Map(Array.from(arr, obj => [obj[prop], []]));\n    arr.forEach(obj => map.get(obj[prop]).push(obj));\n    return Array.from(map.values());\n}\n\nvar groupedUrls  = groupBy(doneBranchUrlMapping, \"record_id\")\n\n// Create Lark Update Json\nvar larkInsertJson = {\n  \"records\": []\n};\n\nfor (let groupedItem of groupedUrls) {\n  var record_id = groupedItem[0].record_id;\n  var workItemJson = groupedItem[0].CommentsJson;\n  \n  var replaceUrls = groupedItem.map((item) => ({originalUrl: item.originalUrl, driveUrl: item.driveUrl}));\n  for (let index = 0; index < replaceUrls.length; index++) {\n    workItemJson = workItemJson.replace(replaceUrls[index].originalUrl, replaceUrls[index].driveUrl)\n  }\n\n  var larkRecord = {\n    \"record_id\": record_id,\n      \"fields\": {\n        \"CommentsAttachmentMappings\": JSON.stringify(replaceUrls),\n        \"CommentsReplacedAttachmentLinkJson\": workItemJson,\n    }\n  \n    };\n    \n  larkInsertJson.records.push(larkRecord);\n}\n\nreturn {\n  a: larkInsertJson\n};"
      },
