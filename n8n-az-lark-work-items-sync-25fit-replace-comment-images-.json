      "parameters": {
        "jsCode": "var allWorkItems = $node[\"Lark. Get All Records\"].json[\"data\"][\"items\"];\n\nconst urlRegex = /\\b((https?|ftp|file):\\/\\/|(www|ftp)\\.)[-A-Z0-9+&@#\\/%?=~_|$!:,.;]*[A-Z0-9+&@#\\/%=~_|$]/ig;\n\nvar attachments = [];\n\nfor (let workItem of allWorkItems) {\n  var workItemJson = workItem[\"fields\"][\"CommentsJson\"];\n  \n  // Extract URLs\n  var urls = workItemJson.match(urlRegex);\n\n  for (let index = 0; index < urls.length; index++) {\n  if(urls[index].includes(\"/attachments/\"))\n  {\n    attachments.push({\n      record_id: workItem.record_id,\n      fileName: decodeURI(urls[index].substring(urls[index].indexOf(\"/attachments/\") + \"/attachments/\".length, urls[index].length).replace(\"?fileName=\", \" - \")),\n      url: urls[index],\n      CommentsJson: workItem.fields.CommentsJson\n    })\n  }\n  }\n}\n\nif(attachments != null && attachments.length > 0)\n  return attachments;\nelse return [];"
