    {
      "parameters": {
        "jsCode": "var workItemJson = $node[\"Az: Max 1 work Items\"].json[\"fields\"][\"WorkItemJson\"];\n//return {  workItemJson: workItemJson };\n\nconst urlRegex = /\\b((https?|ftp|file):\\/\\/|(www|ftp)\\.)[-A-Z0-9+&@#\\/%?=~_|$!:,.;]*[A-Z0-9+&@#\\/%=~_|$]/ig;\n\n// Extract URLs\nvar urls = workItemJson.match(urlRegex);\n\nvar attachments = [];\n// Get Attachment URLs\n//urls = urls.filter((url) => url.includes(\"attachments\"))\nfor (let index = 0; index < urls.length; index++) {\nif(urls[index].includes(\"/attachments/\"))\n{\n  attachments.push({\n    fileName: decodeURI(urls[index].substring(urls[index].indexOf(\"/attachments/\") + \"/attachments/\".length, urls[index].length).replace(\"?fileName=\", \" - \")),\n    url: urls[index]\n  })\n}\n}\n\nif(attachments != null && attachments.length > 0)\n  return attachments;\nelse return [];"
