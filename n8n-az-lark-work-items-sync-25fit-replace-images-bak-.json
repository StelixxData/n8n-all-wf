    {
      "parameters": {
        "jsCode": "var doneBranchUrlMapping = $input.all();\n\ndoneBranchUrlMapping = doneBranchUrlMapping.map((item) => item.json);\n\n\nvar record_id = $node[\"Az: Max 1 work Items\"].json.record_id;\nvar workItemJson = $node[\"Az: Max 1 work Items\"].json[\"fields\"][\"WorkItemJson\"];\ndoneBranchUrlMapping = doneBranchUrlMapping.filter((item) => item.record_id == record_id);\n\nfor (let index = 0; index < doneBranchUrlMapping.length; index++) {\n  workItemJson = workItemJson.replace(doneBranchUrlMapping[index].originalUrl, doneBranchUrlMapping[index].driveUrl)\n}\n\nreturn {\n  \"WorkItemReplacedAttachmentLinkJson\": workItemJson,\n  \"AttachmentMappings\": JSON.stringify(doneBranchUrlMapping)\n}\n"
