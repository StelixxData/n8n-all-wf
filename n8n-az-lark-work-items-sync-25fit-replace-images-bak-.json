    {
      "parameters": {
        "jsCode": "\nvar record_id = $node[\"Az: Max 1 work Items\"].json.record_id;\n\nvar larkInsertJson = {\n  \"records\": []\n};\n\n//return workItems[0];\n\nvar larkRecord = {\n\"record_id\": record_id,\n    \"fields\": {\n    \"AttachmentMappings\": $node[\"Replace\"].json.AttachmentMappings,\n    \"WorkItemReplacedAttachmentLinkJson\": $node[\"Replace\"].json.WorkItemReplacedAttachmentLinkJson,\n  }\n\n  };\n  \n  larkInsertJson.records.push(larkRecord);\n\nreturn {\n  a: larkInsertJson\n};"
