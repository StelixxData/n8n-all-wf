    {
      "parameters": {
        "jsCode": "var settings = $node[\"evn\"].json;\nvar windowTimeInMinutes = settings.windowTimeInMinutes;\nvar minNumberSignalWithInWindowTime = settings.minNumberSignalWithInWindowTime;\nvar trade = $node[\"Webhook\"].json[\"body\"][\"trade\"];\n\nvar getOpenPositionQuery = \n`\nDECLARE @MinSignal INT;\n\nDECLARE @WindowTime INT;\n\n\nSELECT @MinSignal = MinSignal,\n       @WindowTime = WindowTime\nFROM TradeSignalSetting\nWHERE Id = 2; -- Signature\n\nWITH FilteredSignals AS\n  (SELECT TOP (@MinSignal * 10) [Id],\n          [TraderName],\n          [Direction],\n          [TradingPair],\n          [Leverage],\n          [EntryPrice],\n          [ClosingPrice],\n          [PositionSize],\n          [AverageCost],\n          [PNL],\n          [PNLPercentage],\n          [OpenedDate],\n          [ClosedDate],\n          [CreatedDate],\n          [TradeDurationInSecond],\n          [PositionMode],\n          [Status],\n          'Signal' AS SIGNAL,\n          ROW_NUMBER() OVER (PARTITION BY TraderName,\n                                          TradingPair,\n                                          Direction\n                             ORDER BY OpenedDate DESC) AS RowNum\n   FROM [dbo].[FutureSignal]\n   WHERE OpenedDate BETWEEN DATEADD(MINUTE, -(@WindowTime), GETUTCDATE()) AND GETUTCDATE()\n     AND Direction = '${trade[\"actionDirection\"]}'\n     AND TradingPair = '${trade[\"tradingPair\"]}'\n     AND Status = 0\n   ORDER BY OpenedDate DESC),\n\n\nDistinctSignals AS\n  (SELECT TOP (@MinSignal * 10) *\n   FROM FilteredSignals\n   WHERE RowNum = 1\n   ORDER BY OpenedDate DESC)\n\n   \nSELECT TOP 1 *\nFROM DistinctSignals\nWHERE\n    (SELECT COUNT(*)\n     FROM DistinctSignals) >= @MinSignal;\n\n\nSELECT *,\n       'Position' AS POSITION\nFROM TradeSignalSignature\nWHERE TradingPair = '${trade[\"tradingPair\"]}'\n  AND Status = 0\n`\n\nreturn {\n  query: getOpenPositionQuery\n}\n"
      },
