    {
      "parameters": {
        "jsCode": "var signal_postion = $node[\"Aggregate\"].json[\"data\"];\nvar signal;\nvar position;\nvar insertQuery;\nvar telegramPushMessage;\n\n// Vì kết quả SQL trả về 2 bảng chung 1 lần, nên cần tách ra\nif(signal_postion)\n{\n   if(signal_postion.length == 2)\n   {\n     signal = signal_postion[0];\n     position = signal_postion[1];\n   }else if(signal_postion.length == 1)\n   {\n     if(signal_postion[0].SIGNAL)\n       signal = signal_postion[0];\n     else if (signal_postion[0].POSITION)\n       position = signal_postion[0];\n   }\n}\n\nif(position == null && signal) // Không tồn lại Position đang Open và có Signal\n{\ninsertQuery = \n`\nINSERT INTO [dbo].[TradeSignalSignature] ( \n  [Direction], \n  [TradingPair], \n  [Leverage],\n  [EntryPrice], \n  [OpenedDate],\n  [Status],\n  [TradeSignalJson]\n)\nVALUES (\n  N'${signal['Direction']}', \n  N'${signal['TradingPair']}',\n   ${signal['Leverage']}, \n   ${signal['EntryPrice']},  \n   GETUTCDATE(),\n   0,\n   N'${signal[\"TraderName\"]}'\n)`\n  \n  // 2. Alert to Telegram\ntelegramPushMessage = \n`\n<b>#${signal['TradingPair']}</b>\n\n${ signal['Direction'] == \"LONG\" ? \"🟢\" : \"🔴\"} <b>${signal['Direction']}</b>\n\n✦ Entry Price:  <b>${signal['EntryPrice'].toFixed(4)}</b>\n✦ Recommended Leverage:  <b>${signal['Leverage']}x</b>\n✦ Action: <b>Opened Position</b>\n✦ Direction: <b>${ signal['Direction'] }</b>\n\n<i>Disclaimer: Not Financial Advice, Do Your Own Research</i>`\n\n}\n  \nreturn {\n  insertQuery: insertQuery,\n  telegramPushMessage: telegramPushMessage\n};"
      },
