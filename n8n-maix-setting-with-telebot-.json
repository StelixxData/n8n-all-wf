    {
      "parameters": {
        "jsCode": "var text = $node[\"Webhook\"].json[\"body\"][\"message\"][\"text\"];\n\nfunction splitAndRemoveEmpty(str, separator) {\n  return str.split(separator).filter(part => part.trim() !== '');\n}\n\nlet values = splitAndRemoveEmpty(text, \",\");\n\nif(values)\n{\n  if(values[0] == 3) // Luxury\n  {\n    var setting = {\n      WindowTime: values[1],\n      ScoreAtPosition: values[2]\n    };\n  \n  var query = \n`\nUPDATE TradeSignalSetting\nSET Setting = '${ JSON.stringify(setting) }',\n    WindowTime = ${ setting.WindowTime },\n    MinScore = (\n      SELECT TotalScore\n      FROm LeadCopyTrader\n      WHERE [Status] = 'ACTIVE'\n      ORDER BY TotalScore DESC\n      OFFSET (${ setting.ScoreAtPosition - 1 }) ROWS FETCH NEXT 1 ROWS ONLY\n    )\nWHERE Id = ${ values[0] };\n\nSELECT *\nFROM TradeSignalSetting\nWHERE Id = ${ values[0] };\n`;\n  \n  return {\n    query: query\n  }\n  }\n  else{\n  \n  var setting = {\n    MinSignal: values[1],\n    WindowTime: values[2]\n  };\n  \n  var query = \n`\nUPDATE TradeSignalSetting\nSET Setting = '${ JSON.stringify(setting) }',\n    MinSignal = ${ setting.MinSignal },\n    WindowTime = ${ setting.WindowTime }\nWHERE Id = ${ values[0] };\n\nSELECT *\nFROM TradeSignalSetting\nWHERE Id = ${ values[0] };\n`;\n  \n  return {\n    query: query\n  }\n  }\n}"
      },
