    {
      "parameters": {
        "jsCode": "var chatId = $node[\"Webhook\"].json[\"body\"][\"message\"][\"chat\"][\"id\"];\n\nvar telegramMessage = \n`\n<b>Hello, I'm Maix Assistant!</b>\nI can help you manage your MaiX System.\n\nYou can control me by sending these commands:\n\n<b>Maix Setting</b>\n/all - return all settings\n/get - return setting values. Params: {id}\n/update - update setting. Params: {string}\n/set - set value. Param: {string}\n\n<b>Others</b>\n/help - get help\n\n<b>Update Command</b>\nPremium - 1,MinSignal,WindowTime\nSignature - 2,MinSignal,WindowTime\nBullhorn - 4,MinSignal,WindowTime,ScoreAtTopPercent,ScoreTimes,DirectionRatio\nWolfpack - 5,MinSignal,WindowTime,ScoreAtTopPercent,ScoreTimes,DirectionRatio\nTurtleshield - 6,MinSignal,WindowTime,ScoreAtTopPercent,ScoreTimes,DirectionRatio\n`\n\nreturn {\n  chatId: chatId,\n  telegramMessage: telegramMessage\n}"
      },
