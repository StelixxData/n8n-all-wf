    {
      "parameters": {
        "jsCode": "var azWorkItems = $node[\"Az. Get List\"].json[\"value\"];\nvar larkWorkItems = $node[\"Lark. Get Work Item Records\"].json[\"data\"][\"items\"];\nvar newItems = [];\nvar updateItems = [];\nvar exceptionItems = [];\n\nfor (let index = 0; index < azWorkItems.length; index++) {\n  var larkItems = larkWorkItems.filter((p) => p[\"fields\"][\"Id\"] == azWorkItems[index][\"id\"]);\n  if(larkItems.length == 1){\n    updateItems.push({\n        \"record_id\": larkItems[0][\"record_id\"],\n        ...azWorkItems[index]\n      });\n  }else if (larkItems.length == 0) {\n    newItems.push(azWorkItems[index]);\n  }else{\n    exceptionItems.push(azWorkItems[index]);\n  }\n}\n\nreturn {\n  \"newItems\": newItems,\n  \"updateItems\": updateItems,\n  \"exceptionItems\": exceptionItems\n};"
      },
