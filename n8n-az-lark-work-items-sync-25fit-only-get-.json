    {
      "parameters": {
        "jsCode": "var ids = $node[\"WorkItemID200\"].json[\"id\"];\nvar logicalFormulaArray = [];\n\nfor (let index = 0; index < ids.length; index++) {\n  logicalFormulaArray.push(\"CurrentValue.[Id] = \" + ids[index]);\n}\n\nvar orFormulaArray = [];\nconst chunkSize = 30;\nfor (let i = 0; i < logicalFormulaArray.length; i += chunkSize) {\n    let chunk = logicalFormulaArray.slice(i, i + chunkSize);\n    orFormulaArray.push(\"OR(\" + chunk.join() + \")\");\n}\n\n\n\nreturn {\n  ...orFormulaArray\n}\n"
      },
